<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_proxu_screen"
    android:fitsSystemWindows="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="@dimen/proxu_spacing_24">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/proxu_spacing_24">

            <ImageView
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:layout_gravity="center"
                android:src="@mipmap/ic_launcher_foreground"
                android:scaleType="fitCenter"
                android:tint="@color/proxu_text_primary"
                android:tintMode="src_in" />



            <com.google.android.material.button.MaterialButton
                android:id="@+id/google_sign_in_button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="@dimen/proxu_spacing_24"
                android:backgroundTint="@color/colorWhite"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:nextFocusDown="@id/google_sign_in_button"
                android:nextFocusUp="@id/google_sign_in_button"
                android:text="@string/auth_continue_with_google"
                android:textColor="@android:color/black"
                android:textSize="16sp"
                app:cornerRadius="28dp"
                app:icon="@drawable/ic_google_logo"
                app:iconGravity="textStart"
                app:iconPadding="12dp"
                app:iconSize="24dp"
                app:iconTint="@null" />

            <ProgressBar
                android:id="@+id/login_progress_bar"
                style="?android:attr/progressBarStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/proxu_spacing_16"
                android:indeterminateTint="@color/proxu_primary"
                android:visibility="gone" />

            <TextView
                android:id="@+id/error_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/proxu_spacing_16"
                android:gravity="center"
                android:textAppearance="@style/TextAppearance.Proxu.Label"
                android:textColor="@color/proxu_text_secondary"
                android:visibility="gone" />

        </LinearLayout>
    </LinearLayout>
</FrameLayout>
